_do_rsync() {
    local src="$1" dest="$2"
    rsync -az --delete \
        --exclude '.git' \
        --exclude 'node_modules' \
        --exclude '.build' \
        --exclude 'DerivedData' \
        --exclude '*.xcodeproj' \
        --exclude '.DS_Store' \
        --exclude 'Pods' \
        --exclude 'build' \
        --exclude '.claude' \
        -e "ssh -i $SSH_KEY -o StrictHostKeyChecking=no" \
        "$src/" "$EC2_USER@$EC2_HOST:$dest/" 2>&1
}

cmd_sync() {
    require_config

    # Parse flags: optional path and --watch/-w
    local WATCH=false PROJECT_DIR=""
    shift  # drop "sync"
    while [ $# -gt 0 ]; do
        case "$1" in
            --watch|-w) WATCH=true; shift ;;
            -*) shift ;;
            *)  PROJECT_DIR="$1"; shift ;;
        esac
    done
    PROJECT_DIR="${PROJECT_DIR:-$(pwd)}"

    echo -e "${PURPLE}${BOLD}Pocket Eng${NC} — Sync to EC2"
    echo ""
    local REMOTE_PROJECT="$WORK_DIR/$(basename "$PROJECT_DIR")"
    echo -e "  ${BOLD}$(basename "$PROJECT_DIR")${NC}  →  ${DIM}$EC2_HOST:$REMOTE_PROJECT${NC}"
    echo ""

    # Ensure rsync is available on remote
    if ! ssh_cmd "command -v rsync" &>/dev/null; then
        ssh_cmd "sudo dnf install -y rsync 2>/dev/null || sudo yum install -y rsync 2>/dev/null || sudo apt-get install -y rsync 2>/dev/null" &>/dev/null
    fi
    ssh_cmd "mkdir -p '$REMOTE_PROJECT'" 2>/dev/null

    # Initial sync
    local out
    out=$(_do_rsync "$PROJECT_DIR" "$REMOTE_PROJECT")
    if [ $? -eq 0 ]; then
        echo -e "  ${GREEN}✓${NC} Synced"
    else
        echo -e "  ${RED}Sync failed${NC}"
        echo -e "  ${DIM}$out${NC}"
        return 1
    fi

    if $WATCH; then
        echo ""
        echo -e "  ${DIM}Watching for changes...  Ctrl+C to stop${NC}"
        echo ""
        _sync_one() {
            local o
            o=$(_do_rsync "$PROJECT_DIR" "$REMOTE_PROJECT")
            if [ $? -eq 0 ]; then
                echo -e "  ${GREEN}✓${NC} $(date +%H:%M:%S)"
            else
                echo -e "  ${RED}✗${NC} $(date +%H:%M:%S) — ${DIM}$(echo "$o" | head -1)${NC}"
            fi
        }
        if command -v fswatch &>/dev/null; then
            fswatch -o --exclude '\.git' --exclude 'node_modules' "$PROJECT_DIR" \
                | while read -r _; do _sync_one; done
        elif command -v inotifywait &>/dev/null; then
            while inotifywait -r -q -e modify,create,delete,move \
                --exclude '(\.git|node_modules)' "$PROJECT_DIR" 2>/dev/null; do
                _sync_one
            done
        else
            echo -e "  ${YELLOW}fswatch not found${NC} — polling every 3s  ${DIM}(brew install fswatch for native watching)${NC}"
            echo ""
            while true; do sleep 3; _sync_one; done
        fi
    else
        echo ""
        echo -e "  ${DIM}pocketeng — to open a session on EC2${NC}"
        echo -e "  ${DIM}pocketeng sync --watch — live sync on every save${NC}"
        echo ""
    fi
}

cmd_servers() {
    migrate_config
    echo -e "${PURPLE}${BOLD}Pocket Eng${NC} — Servers"
    echo ""
    local current
    current=$(active_profile)
    if [ ! -d "$SERVERS_DIR" ] || [ -z "$(ls "$SERVERS_DIR"/*.conf 2>/dev/null)" ]; then
        echo -e "  ${DIM}No servers configured. Run ${NC}${BOLD}pocketeng init${NC}${DIM} or ${NC}${BOLD}pocketeng setup${NC}"
        echo ""
        return
    fi
    for f in "$SERVERS_DIR"/*.conf; do
        local name
        name=$(basename "$f" .conf)
        local host=""
        source "$f"
        host="${PE_HOST:-unknown}"
        if [ "$name" = "$current" ]; then
            echo -e "  ${GREEN}●${NC} ${BOLD}$name${NC}$(printf '%*s' $((16 - ${#name})) '')$host  ${GREEN}(active)${NC}"
        else
            echo -e "    $name$(printf '%*s' $((16 - ${#name})) '')$host"
        fi
    done
    echo ""
    echo -e "  ${DIM}Switch: pocketeng switch <name>${NC}"
    echo ""
}

cmd_switch() {
    local target="$1"
    if [ -z "$target" ]; then
        echo "Usage: pocketeng switch <server-name>"
        echo ""
        cmd_servers
        exit 1
    fi
    migrate_config
    local pfile="$SERVERS_DIR/${target}.conf"
    if [ ! -f "$pfile" ]; then
        echo -e "${RED}Server '$target' not found.${NC}"
        echo ""
        cmd_servers
        exit 1
    fi
    # Load the target profile and write it as active
    source "$pfile"
    EC2_HOST="${PE_HOST:-}"
    EC2_USER="${PE_USER:-ec2-user}"
    SSH_KEY="${PE_KEY:-$HOME/.ssh/pocketeng.pem}"
    WORK_DIR="${PE_DIR:-~/projects}"
    save_config "$target"
    echo -e "${GREEN}Switched to ${BOLD}$target${NC} ${DIM}($EC2_HOST)${NC}"
    echo ""
    # Quick connectivity check
    echo -n "  Testing connection... "
    if ssh_cmd -o BatchMode=yes "echo ok" &>/dev/null; then
        echo -e "${GREEN}Connected!${NC}"
    else
        echo -e "${YELLOW}Could not connect${NC}"
    fi
}

cmd_help() {
    echo -e "${PURPLE}${BOLD}Pocket Eng${NC} v$VERSION — Claude Code on your cloud, from anywhere."
    echo ""
    echo "Getting started:"
    echo "  pocketeng                      First run: scan QR with Pocket Eng app to provision"
    echo "  pocketeng init                 Provision via phone app (scan QR)"
    echo "  pocketeng init --manual        Provision via wizard (no phone required)"
    echo "  pocketeng setup                Connect to an existing EC2"
    echo ""
    echo "Daily use:"
    echo "  pocketeng                      Start or resume interactive Claude Code session"
    echo "  pocketeng attach                Reattach to running session"
    echo "  pocketeng resume               Pick and resume a past session"
    echo "  pocketeng list                  List sessions"
    echo "  pocketeng status                Check if Claude is running"
    echo "  pocketeng qr                    Show QR code for phone app"
    echo "  pocketeng logs                  Show EC2 setup/install log"
    echo "  pocketeng sync [path]           Sync current directory to EC2
  pocketeng sync --watch          Live sync — re-sync on every file save"
    echo ""
    echo "Multi-server:"
    echo "  pocketeng servers               List all configured servers"
    echo "  pocketeng switch <name>          Switch active server"
    echo "  pocketeng setup --name <name>    Add a named server"
    echo "  pocketeng sync --server <name>   Sync to a specific server"
    echo ""
    echo "How it works:"
    echo "  1. brew install pocketeng (or curl install)"
    echo "  2. Run 'pocketeng' — scan the QR code with the Pocket Eng app"
    echo "  3. Tap 'Spin up EC2' in the app — done in ~2 minutes"
    echo "  4. Code from laptop or phone — sessions survive disconnects"
}

# ─── Main ────────────────────────────────────────────────────────────────────

# Parse global --server flag from any position
ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --server) SERVER_OVERRIDE="$2"; shift 2 ;;
        --server=*) SERVER_OVERRIDE="${1#*=}"; shift ;;
        *) ARGS+=("$1"); shift ;;
    esac
done
set -- "${ARGS[@]}"

load_config

case "${1:-}" in
    init)           cmd_init "$@" ;;
    setup)          cmd_setup "$@" ;;
    sync)           cmd_sync "$@" ;;
    servers|--servers)   cmd_servers ;;
    switch)         cmd_switch "${2:-}" ;;
    list|--list|-l)      cmd_list ;;
    resume|--resume|-r)  cmd_resume "${2:-}" ;;
    attach|--attach|-a)  cmd_attach ;;
    status|--status|-s)  cmd_status ;;
    qr|--qr)             cmd_qr ;;
    logs|--logs)         cmd_logs ;;
    help|--help|-h)      cmd_help ;;
    version|--version|-v) echo "pocketeng v$VERSION" ;;
    "")             [ -z "$EC2_HOST" ] && cmd_init || cmd_interactive ;;
    -*)             echo "Unknown option: $1"; cmd_help; exit 1 ;;
    *)              echo "Unknown command: $1"; cmd_help; exit 1 ;;
esac
