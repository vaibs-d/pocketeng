# ─── Setup: Connect to existing EC2 ─────────────────────────────────────────

cmd_setup() {
    local PROFILE_NAME=""
    # Parse --name flag
    shift 2>/dev/null || true  # skip "setup"
    while [ $# -gt 0 ]; do
        case "$1" in
            --name) PROFILE_NAME="$2"; shift 2 ;;
            --name=*) PROFILE_NAME="${1#*=}"; shift ;;
            *) shift ;;
        esac
    done

    echo -e "${PURPLE}${BOLD}Pocket Eng${NC} — Connect to existing EC2"
    echo ""

    if [ -z "$PROFILE_NAME" ]; then
        read -p "  Server name [default]: " PROFILE_NAME
        PROFILE_NAME="${PROFILE_NAME:-default}"
    fi
    echo ""

    read -p "  EC2 host (IP or hostname): " input_host
    [ -z "$input_host" ] && echo "Host is required." && exit 1
    EC2_HOST="$input_host"

    read -p "  SSH user [ec2-user]: " input_user
    EC2_USER="${input_user:-ec2-user}"

    local default_key="$HOME/.ssh/pocketeng.pem"
    read -p "  SSH key path [$default_key]: " input_key
    SSH_KEY="${input_key:-$default_key}"
    [ ! -f "$SSH_KEY" ] && echo -e "  ${YELLOW}Warning: Key not found at $SSH_KEY${NC}"

    read -p "  Working directory [~/projects]: " input_dir
    WORK_DIR="${input_dir:-~/projects}"

    save_config "$PROFILE_NAME"
    echo ""
    echo -n "  Testing connection... "
    if ssh_cmd -o BatchMode=yes "echo ok" &>/dev/null; then
        echo -e "${GREEN}Connected!${NC}"
        echo -e "  Run ${BOLD}pocketeng${NC} to start."
    else
        echo -e "${YELLOW}Could not connect${NC}"
    fi
}

# ─── EC2 State ───────────────────────────────────────────────────────────────

# Returns 0 if the instance is (now) running, 1 otherwise.
# If stopped, offers to start it and updates EC2_HOST if the IP changed.
_start_ec2_if_stopped() {
    [ -z "$EC2_INSTANCE_ID" ] && return 1
    command -v aws &>/dev/null || return 1

    local state
    state=$(aws ec2 describe-instances --instance-ids "$EC2_INSTANCE_ID" \
        --query 'Reservations[0].Instances[0].State.Name' --output text 2>/dev/null)

    case "$state" in
        running) return 0 ;;
        stopped)
            echo -e "  ${YELLOW}EC2 instance is stopped.${NC}"
            read -p "  Start it? [Y/n] " _choice
            _choice="${_choice:-y}"
            [[ "$_choice" =~ ^[Yy] ]] || return 1

            echo -n "  Starting"
            aws ec2 start-instances --instance-ids "$EC2_INSTANCE_ID" &>/dev/null
            for _ in $(seq 1 24); do
                sleep 5; echo -n "."
                local new_state new_ip
                new_state=$(aws ec2 describe-instances --instance-ids "$EC2_INSTANCE_ID" \
                    --query 'Reservations[0].Instances[0].State.Name' --output text 2>/dev/null)
                new_ip=$(aws ec2 describe-instances --instance-ids "$EC2_INSTANCE_ID" \
                    --query 'Reservations[0].Instances[0].PublicIpAddress' --output text 2>/dev/null)
                if [ "$new_state" = "running" ] && [ -n "$new_ip" ] && [ "$new_ip" != "None" ]; then
                    echo -e " ${GREEN}running${NC}"
                    if [ "$new_ip" != "$EC2_HOST" ]; then
                        echo -e "  ${DIM}IP updated: $EC2_HOST → $new_ip${NC}"
                        EC2_HOST="$new_ip"
                        save_config "$(active_profile)"
                    fi
                    return 0
                fi
            done
            echo -e " ${RED}timed out${NC}"
            return 1
            ;;
        *) return 1 ;;
    esac
}

# ─── Session Commands ────────────────────────────────────────────────────────

cmd_interactive() {
    require_config
    echo -e "${PURPLE}${BOLD}Pocket Eng${NC} — Interactive mode"
    echo -e "${DIM}Close laptop anytime — session keeps running on EC2.${NC}"
    echo -e "${DIM}Reattach: pocketeng attach | Phone: open Pocket Eng app${NC}"
    echo ""
    ssh_cmd -t "tmux kill-session -t $TMUX_SESSION 2>/dev/null; tmux new-session -s $TMUX_SESSION -c $WORK_DIR 'claude'"
}


cmd_resume() {
    require_config
    local sid="$1"

    # No ID given — show interactive list to pick from
    if [ -z "$sid" ]; then
        echo -e "${PURPLE}${BOLD}Pocket Eng${NC} — Recent sessions"
        echo ""
        local sessions
        sessions=$(ssh_cmd "
            for dir in ~/.claude/projects/*/; do
                for f in \"\$dir\"*.jsonl; do
                    [ -f \"\$f\" ] || continue
                    s=\$(basename \"\$f\" .jsonl)
                    echo \"\$s\" | grep -q '^agent-' && continue
                    first=\$(head -1 \"\$f\" | grep -oP '\"content\":\"\\K[^\"]+' | head -c 60)
                    last=\$(tail -1 \"\$f\" | grep -oP '\"timestamp\":\"\\K[^\"]+')
                    printf '%s\t%s\t%s\n' \"\$s\" \"\$last\" \"\$first\"
                done
            done | sort -k2 -r | head -10
        " 2>/dev/null)

        if [ -z "$sessions" ]; then
            echo -e "  ${DIM}No sessions found.${NC}"
            return
        fi

        local i=1
        local -a sids
        while IFS=$'\t' read -r s ts preview; do
            printf "  ${BOLD}%2d${NC}  ${DIM}%s${NC}  %s\n" "$i" "${ts%T*}" "$preview"
            sids[$i]="$s"
            i=$((i + 1))
        done <<< "$sessions"

        echo ""
        read -p "  Pick a session [1]: " choice
        choice="${choice:-1}"
        sid="${sids[$choice]}"
        [ -z "$sid" ] && echo "Invalid choice." && exit 1
    fi

    echo -e "${PURPLE}${BOLD}Pocket Eng${NC} — Resuming ${sid:0:8}..."
    ssh_cmd -t "tmux kill-session -t $TMUX_SESSION 2>/dev/null; tmux new-session -s $TMUX_SESSION -c $WORK_DIR 'claude --resume \"$sid\"'"
}

cmd_attach() {
    require_config
    local tmux_state
    tmux_state=$(ssh_cmd "tmux has-session -t $TMUX_SESSION 2>/dev/null && echo RUNNING || echo STOPPED" 2>/dev/null)

    # SSH returned nothing — instance may be stopped
    if [ -z "$tmux_state" ]; then
        echo -e "${PURPLE}${BOLD}Pocket Eng${NC} — Cannot reach $EC2_HOST"
        echo ""
        if _start_ec2_if_stopped; then
            echo -n "  Waiting for SSH"
            for _ in $(seq 1 12); do
                sleep 5; echo -n "."
                tmux_state=$(ssh_cmd "tmux has-session -t $TMUX_SESSION 2>/dev/null && echo RUNNING || echo STOPPED" 2>/dev/null)
                [ -n "$tmux_state" ] && break
            done
            echo ""
        fi
    fi

    if [ "$tmux_state" = "RUNNING" ]; then
        echo -e "${PURPLE}${BOLD}Pocket Eng${NC} — Reattaching..."
        ssh_cmd -t "tmux attach-session -t $TMUX_SESSION"
    else
        echo -e "${PURPLE}${BOLD}Pocket Eng${NC} — No active session."
        echo ""
        read -p "  Start a new session? [Y/n] " choice
        choice="${choice:-y}"
        [[ "$choice" =~ ^[Yy] ]] && cmd_interactive
    fi
}

