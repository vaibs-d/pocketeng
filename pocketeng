#!/bin/bash
# Pocket Eng — Claude Code on your cloud, from anywhere.
# Sessions run in tmux on EC2, surviving disconnects.
# Close your laptop, pick up on your phone, or reconnect later.
#
# Install:  curl -fsSL https://pocketeng.co/install | sh
# Start:    pocketeng init
# Docs:     https://github.com/vaibs-d/pocketengineer

VERSION="1.2.0"
CONFIG_DIR="$HOME/.pocketeng"
LEGACY_DIR="$HOME/.pocket-engineer"
CONFIG_FILE="$CONFIG_DIR/config"
SERVERS_DIR="$CONFIG_DIR/servers"
ACTIVE_FILE="$CONFIG_DIR/active"
TMUX_SESSION="pocketeng"
SERVER_OVERRIDE=""

# Colors
PURPLE='\033[0;35m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# ─── Config ──────────────────────────────────────────────────────────────────

# Migrate old ~/.pocket-engineer dir to ~/.pocketeng
migrate_dir() {
    if [ -d "$LEGACY_DIR" ] && [ ! -d "$CONFIG_DIR" ]; then
        mv "$LEGACY_DIR" "$CONFIG_DIR"
    fi
}

# Migrate old single-server config to multi-server layout
migrate_config() {
    migrate_dir
    if [ -f "$CONFIG_FILE" ] && [ ! -d "$SERVERS_DIR" ]; then
        mkdir -p "$SERVERS_DIR"
        cp "$CONFIG_FILE" "$SERVERS_DIR/default.conf"
        echo "default" > "$ACTIVE_FILE"
    fi
}

active_profile() {
    if [ -n "$SERVER_OVERRIDE" ]; then
        echo "$SERVER_OVERRIDE"
    elif [ -f "$ACTIVE_FILE" ]; then
        cat "$ACTIVE_FILE"
    else
        echo "default"
    fi
}

load_config() {
    migrate_config
    local profile="${1:-$(active_profile)}"
    local pfile="$SERVERS_DIR/${profile}.conf"
    if [ -f "$pfile" ]; then
        source "$pfile"
    elif [ -n "$SERVER_OVERRIDE" ]; then
        echo -e "${RED}Server '$SERVER_OVERRIDE' not found.${NC}"
        echo ""
        cmd_servers
        exit 1
    elif [ -f "$CONFIG_FILE" ]; then
        source "$CONFIG_FILE"
    fi
    EC2_HOST="${POCKET_ENGINEER_HOST:-${PE_HOST:-}}"
    EC2_USER="${POCKET_ENGINEER_USER:-${PE_USER:-ec2-user}}"
    SSH_KEY="${POCKET_ENGINEER_KEY:-${PE_KEY:-$HOME/.ssh/pocketeng.pem}}"
    WORK_DIR="${POCKET_ENGINEER_DIR:-${PE_DIR:-~/projects}}"
    EC2_INSTANCE_ID="${PE_INSTANCE_ID:-}"
}

save_config() {
    local profile="${1:-$(active_profile)}"
    mkdir -p "$SERVERS_DIR"
    cat > "$SERVERS_DIR/${profile}.conf" << EOF
# Pocket Eng — server profile: $profile
PE_HOST="$EC2_HOST"
PE_USER="$EC2_USER"
PE_KEY="$SSH_KEY"
PE_DIR="$WORK_DIR"
PE_INSTANCE_ID="$EC2_INSTANCE_ID"
EOF
    chmod 600 "$SERVERS_DIR/${profile}.conf"
    # Write legacy config for backward compat (always reflects active)
    cat > "$CONFIG_FILE" << EOF
# Pocket Eng CLI config (active: $profile)
PE_HOST="$EC2_HOST"
PE_USER="$EC2_USER"
PE_KEY="$SSH_KEY"
PE_DIR="$WORK_DIR"
PE_INSTANCE_ID="$EC2_INSTANCE_ID"
EOF
    chmod 600 "$CONFIG_FILE"
    echo "$profile" > "$ACTIVE_FILE"
}

require_config() {
    if [ -z "$EC2_HOST" ]; then
        echo -e "${RED}Not configured.${NC} Run ${BOLD}pocketeng init${NC} to get started."
        exit 1
    fi
}

# ─── SSH ─────────────────────────────────────────────────────────────────────

ssh_cmd() {
    ssh -i "$SSH_KEY" \
        -o StrictHostKeyChecking=no \
        -o ServerAliveInterval=30 \
        -o ConnectTimeout=10 \
        "$EC2_USER@$EC2_HOST" "$@"
}

# ─── QR Code ─────────────────────────────────────────────────────────────────

generate_qr() {
    local data="$1"
    python3 -c "
import sys
data = sys.argv[1]
try:
    import qrcode
    qr = qrcode.QRCode(version=None, box_size=1, border=1, error_correction=qrcode.constants.ERROR_CORRECT_L)
    qr.add_data(data)
    qr.make(fit=True)
    m = qr.modules
    for r in range(0, len(m) - 1, 2):
        line = '  '
        for c in range(len(m[r])):
            top, bot = m[r][c], m[r+1][c] if r+1 < len(m) else False
            if top and bot: line += chr(0x2588)
            elif top: line += chr(0x2580)
            elif bot: line += chr(0x2584)
            else: line += ' '
        print(line)
    if len(m) % 2 == 1:
        print('  ' + ''.join(chr(0x2580) if m[-1][c] else ' ' for c in range(len(m[-1]))))
except ImportError:
    import subprocess
    print('  Installing qrcode library...')
    subprocess.check_call([sys.executable, '-m', 'pip', 'install', '-q', 'qrcode'], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    import qrcode
    qr = qrcode.QRCode(version=None, box_size=1, border=1, error_correction=qrcode.constants.ERROR_CORRECT_L)
    qr.add_data(data)
    qr.make(fit=True)
    m = qr.modules
    for r in range(0, len(m) - 1, 2):
        line = '  '
        for c in range(len(m[r])):
            top, bot = m[r][c], m[r+1][c] if r+1 < len(m) else False
            if top and bot: line += chr(0x2588)
            elif top: line += chr(0x2580)
            elif bot: line += chr(0x2584)
            else: line += ' '
        print(line)
    if len(m) % 2 == 1:
        print('  ' + ''.join(chr(0x2580) if m[-1][c] else ' ' for c in range(len(m[-1]))))
" "$data" 2>/dev/null
}

# ─── Init: EC2 provisioning (shared by pairing + manual wizard) ──────────────

_do_provision() {
    if ! command -v aws &>/dev/null; then
        echo -e "${RED}AWS CLI required.${NC} Install: brew install awscli"
        exit 1
    fi

    [ -n "$PE_AWS_KEY" ] && export AWS_ACCESS_KEY_ID="$PE_AWS_KEY"
    [ -n "$PE_AWS_SECRET" ] && export AWS_SECRET_ACCESS_KEY="$PE_AWS_SECRET"
    export AWS_DEFAULT_REGION="$PE_AWS_REGION"

    local KEY_NAME="pe-$(openssl rand -hex 4)"
    local SG_NAME="pe-$(openssl rand -hex 4)"
    mkdir -p "$CONFIG_DIR"
    local KEY_FILE="$CONFIG_DIR/${KEY_NAME}.pem"

    # Create key pair
    echo -n "  Creating SSH key pair... "
    aws ec2 create-key-pair \
        --key-name "$KEY_NAME" --key-type ed25519 \
        --query 'KeyMaterial' --output text > "$KEY_FILE" 2>/dev/null
    chmod 600 "$KEY_FILE"
    echo -e "${GREEN}done${NC}"

    # Security group
    echo -n "  Creating security group... "
    local SG_ID
    SG_ID=$(aws ec2 create-security-group \
        --group-name "$SG_NAME" \
        --description "Pocket Eng" \
        --query 'GroupId' --output text 2>/dev/null)
    aws ec2 authorize-security-group-ingress --group-id "$SG_ID" --protocol tcp --port 22 --cidr 0.0.0.0/0 &>/dev/null
    aws ec2 authorize-security-group-ingress --group-id "$SG_ID" --protocol tcp --port 8080 --cidr 0.0.0.0/0 &>/dev/null
    [[ "$PE_DOCKER" =~ ^[Yy] ]] && aws ec2 authorize-security-group-ingress --group-id "$SG_ID" --protocol tcp --port 3000 --cidr 0.0.0.0/0 &>/dev/null
    echo -e "${GREEN}$SG_ID${NC}"

    # AMI
    echo -n "  Finding AMI... "
    local AMI_ID
    AMI_ID=$(aws ec2 describe-images --owners amazon \
        --filters "Name=name,Values=al2023-ami-2023*-x86_64" "Name=state,Values=available" \
        --query 'Images | sort_by(@, &CreationDate) | [-1].ImageId' --output text 2>/dev/null)
    if [ -z "$AMI_ID" ] || [ "$AMI_ID" = "None" ]; then
        case "$PE_AWS_REGION" in
            us-east-1) AMI_ID="ami-0c02fb55956c7d316" ;;
            us-west-2) AMI_ID="ami-0dc8f589abe99f538" ;;
            *) echo -e "${RED}No AMI for $PE_AWS_REGION${NC}"; exit 1 ;;
        esac
    fi
    echo -e "${GREEN}$AMI_ID${NC}"

    # Build user-data script as a temp file (avoids shell quoting hell)
    local USERDATA_FILE
    USERDATA_FILE=$(mktemp)

    cat > "$USERDATA_FILE" << 'BASE_EOF'
#!/bin/bash
exec > /var/log/pocketeng-setup.log 2>&1
echo "=== Pocket Eng setup started ==="

# Base packages
echo "--- Installing base packages ---"
dnf install -y nodejs20 npm git tmux python3 python3-pip jq tar gzip unzip which rsync

echo "--- Installing Claude Code ---"
npm install -g @anthropic-ai/claude-code

echo "--- Installing Python packages ---"
pip3 install flask requests boto3 || true

BASE_EOF

    # GitHub CLI
    if [[ "$PE_GITHUB" =~ ^[Yy] ]]; then
        cat >> "$USERDATA_FILE" << 'GH_EOF'
echo "--- Installing GitHub CLI ---"
dnf install -y https://github.com/cli/cli/releases/download/v2.67.0/gh_2.67.0_linux_amd64.rpm || echo "WARN: gh install failed"
GH_EOF
        if [ -n "$PE_GITHUB_TOKEN" ]; then
            cat >> "$USERDATA_FILE" << GHTOKEN_EOF
su - ec2-user -c 'mkdir -p ~/.config/gh && cat > ~/.config/gh/hosts.yml << GHCFG
github.com:
    oauth_token: $PE_GITHUB_TOKEN
    user: ""
    git_protocol: https
GHCFG'
GHTOKEN_EOF
        fi
    fi

    # Vercel
    if [[ "$PE_VERCEL" =~ ^[Yy] ]]; then
        cat >> "$USERDATA_FILE" << 'VERCEL_EOF'
echo "--- Installing Vercel ---"
npm install -g vercel || echo "WARN: vercel install failed"
VERCEL_EOF
        if [ -n "$PE_VERCEL_TOKEN" ]; then
            echo "echo 'export VERCEL_TOKEN=$PE_VERCEL_TOKEN' >> /home/ec2-user/.bashrc" >> "$USERDATA_FILE"
        fi
    fi

    # Supabase
    if [[ "$PE_SUPABASE" =~ ^[Yy] ]]; then
        cat >> "$USERDATA_FILE" << 'SUPA_EOF'
echo "--- Installing Supabase ---"
npm install -g supabase || echo "WARN: supabase install failed"
SUPA_EOF
        if [ -n "$PE_SUPABASE_TOKEN" ]; then
            echo "echo 'export SUPABASE_ACCESS_TOKEN=$PE_SUPABASE_TOKEN' >> /home/ec2-user/.bashrc" >> "$USERDATA_FILE"
        fi
    fi

    # Docker
    if [[ "$PE_DOCKER" =~ ^[Yy] ]]; then
        cat >> "$USERDATA_FILE" << 'DOCKER_EOF'
echo "--- Installing Docker ---"
dnf install -y docker || echo "WARN: docker install failed"
systemctl enable docker
systemctl start docker
usermod -aG docker ec2-user
DOCKER_EOF
    fi

    # OpenAI Codex
    if [[ "$PE_CODEX" =~ ^[Yy] ]]; then
        cat >> "$USERDATA_FILE" << 'CODEX_EOF'
echo "--- Installing OpenAI Codex ---"
npm install -g @openai/codex || echo "WARN: codex install failed"
CODEX_EOF
        if [ -n "$PE_OPENAI_KEY" ]; then
            echo "echo 'export OPENAI_API_KEY=$PE_OPENAI_KEY' >> /home/ec2-user/.bashrc" >> "$USERDATA_FILE"
        fi
    fi

    # AWS CLI
    if [[ "$PE_AWSCLI" =~ ^[Yy] ]]; then
        cat >> "$USERDATA_FILE" << 'AWSCLI_BASE_EOF'
echo "--- Installing AWS CLI ---"
curl -sL "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o /tmp/awscli.zip
unzip -q /tmp/awscli.zip -d /tmp && /tmp/aws/install && rm -rf /tmp/aws /tmp/awscli.zip || echo "WARN: awscli install failed"
AWSCLI_BASE_EOF
        if [ -n "$PE_AWS_KEY" ]; then
            cat >> "$USERDATA_FILE" << AWSCLI_KEYS_EOF
echo 'export AWS_ACCESS_KEY_ID=$PE_AWS_KEY' >> /home/ec2-user/.bashrc
echo 'export AWS_SECRET_ACCESS_KEY=$PE_AWS_SECRET' >> /home/ec2-user/.bashrc
AWSCLI_KEYS_EOF
        fi
        cat >> "$USERDATA_FILE" << AWSCLI_REGION_EOF
echo 'export AWS_DEFAULT_REGION=$PE_AWS_REGION' >> /home/ec2-user/.bashrc
AWSCLI_REGION_EOF
    fi

    # Always: Anthropic key, project dir, git config, tmux, ready marker
    cat >> "$USERDATA_FILE" << FINAL_EOF
echo "--- Configuring environment ---"
echo 'export ANTHROPIC_API_KEY=$PE_ANTHROPIC_KEY' >> /home/ec2-user/.bashrc
mkdir -p /home/ec2-user/projects && chown -R ec2-user:ec2-user /home/ec2-user/projects
su - ec2-user -c 'git config --global user.name "Pocket Eng"'
su - ec2-user -c 'git config --global user.email "dev@pocketengineer.dev"'

cat > /home/ec2-user/.tmux.conf << 'TMUXEOF'
set -g mouse on
set -g history-limit 50000
set -g status-style 'bg=#1e1e2e fg=#cdd6f4'
TMUXEOF
chown ec2-user:ec2-user /home/ec2-user/.tmux.conf

echo "=== Verifying installations ==="
echo "node: \$(node --version 2>/dev/null || echo MISSING)"
echo "npm: \$(npm --version 2>/dev/null || echo MISSING)"
echo "claude: \$(which claude 2>/dev/null || echo MISSING)"
echo "git: \$(git --version 2>/dev/null || echo MISSING)"
echo "python3: \$(python3 --version 2>/dev/null || echo MISSING)"
command -v gh &>/dev/null && echo "gh: \$(gh --version 2>/dev/null | head -1)" || true
command -v docker &>/dev/null && echo "docker: \$(docker --version 2>/dev/null)" || true
command -v vercel &>/dev/null && echo "vercel: installed" || true
command -v aws &>/dev/null && echo "aws: \$(aws --version 2>/dev/null)" || true

echo "=== Setup complete ==="
touch /home/ec2-user/.pocketeng-ready
FINAL_EOF

    # Launch
    echo -n "  Launching EC2 (t3.medium)... "
    local INSTANCE_ID
    INSTANCE_ID=$(aws ec2 run-instances \
        --image-id "$AMI_ID" --instance-type t3.medium \
        --key-name "$KEY_NAME" --security-group-ids "$SG_ID" \
        --user-data "file://$USERDATA_FILE" \
        --tag-specifications "ResourceType=instance,Tags=[{Key=Name,Value=PocketEngineer},{Key=ManagedBy,Value=PocketEngineer}]" \
        --query 'Instances[0].InstanceId' --output text 2>/dev/null)
    rm -f "$USERDATA_FILE"
    echo -e "${GREEN}$INSTANCE_ID${NC}"

    # Wait for IP
    echo -n "  Waiting for public IP"
    local PUBLIC_IP=""
    for _ in $(seq 1 30); do
        sleep 10
        echo -n "."
        PUBLIC_IP=$(aws ec2 describe-instances --instance-ids "$INSTANCE_ID" \
            --query 'Reservations[0].Instances[0].PublicIpAddress' --output text 2>/dev/null)
        [ -n "$PUBLIC_IP" ] && [ "$PUBLIC_IP" != "None" ] && break
    done
    if [ -z "$PUBLIC_IP" ] || [ "$PUBLIC_IP" = "None" ]; then
        echo -e " ${RED}failed${NC}"; exit 1
    fi
    echo -e " ${GREEN}$PUBLIC_IP${NC}"

    # Wait for setup completion
    echo -n "  Installing tools"
    for _ in $(seq 1 36); do
        sleep 5
        echo -n "."
        if ssh -i "$KEY_FILE" -o StrictHostKeyChecking=no -o ConnectTimeout=5 -o BatchMode=yes \
           "ec2-user@$PUBLIC_IP" "test -f ~/.pocketeng-ready" &>/dev/null 2>&1; then
            break
        fi
    done
    echo -e " ${GREEN}done${NC}"

    # Show what was installed
    echo ""
    echo -e "  ${BOLD}Installed tools:${NC}"
    local INSTALL_LOG
    INSTALL_LOG=$(ssh -i "$KEY_FILE" -o StrictHostKeyChecking=no -o ConnectTimeout=5 \
        "ec2-user@$PUBLIC_IP" "grep -E '^(node|npm|claude|git|python3|gh|docker|vercel|aws):' /var/log/pocketeng-setup.log 2>/dev/null" 2>/dev/null || true)
    if [ -n "$INSTALL_LOG" ]; then
        while IFS= read -r line; do
            echo -e "    ${GREEN}✓${NC} $line"
        done <<< "$INSTALL_LOG"
    else
        echo -e "    ${DIM}(log not available yet — tools are installing in background)${NC}"
    fi

    # Save config
    EC2_HOST="$PUBLIC_IP"
    EC2_USER="ec2-user"
    SSH_KEY="$KEY_FILE"
    WORK_DIR="~/projects"
    EC2_INSTANCE_ID="$INSTANCE_ID"
    save_config "$PE_SERVER_NAME"

    echo ""
    echo -e "${GREEN}${BOLD}  Your dev environment is ready!${NC}"
    echo ""
    echo -e "  Host:      ${BOLD}$PUBLIC_IP${NC}"
    echo -e "  SSH Key:   ${DIM}$KEY_FILE${NC}"
    echo -e "  Instance:  ${DIM}$INSTANCE_ID${NC}"
    echo ""
    echo -e "  ${BOLD}Laptop:${NC}  pocketeng"
    echo -e "  ${BOLD}Phone:${NC}   Scan the QR code below in the Pocket Eng app"
    echo ""

    # QR code for phone app
    local KEY_B64
    KEY_B64=$(base64 < "$KEY_FILE" | tr -d '\n')
    local QR_DATA="pe://$PUBLIC_IP:22?key=$KEY_B64"

    echo -e "  ${PURPLE}${BOLD}Scan with Pocket Eng app:${NC}"
    echo ""
    generate_qr "$QR_DATA"
    echo ""
    echo -e "  ${DIM}Or enter manually in app — Host: $PUBLIC_IP${NC}"
    echo ""
}

# ─── Init: Provision new EC2 (phone pairing — default) ──────────────────────

# Detect which credentials are already present on this Mac
_detect_local_creds() {
    # Anthropic key
    PE_ANTHROPIC_KEY="${ANTHROPIC_API_KEY:-}"
    if [ -z "$PE_ANTHROPIC_KEY" ]; then
        PE_ANTHROPIC_KEY=$(python3 -c "
import os, json
# Claude Code stores it in ~/.claude.json
p = os.path.expanduser('~/.claude.json')
if os.path.exists(p):
    d = json.load(open(p))
    print(d.get('primaryApiKey', d.get('apiKey', '')))
" 2>/dev/null)
    fi

    # AWS credentials
    PE_AWS_KEY="${AWS_ACCESS_KEY_ID:-}"
    PE_AWS_SECRET="${AWS_SECRET_ACCESS_KEY:-}"
    PE_AWS_REGION="${AWS_DEFAULT_REGION:-}"
    if [ -z "$PE_AWS_KEY" ]; then
        PE_AWS_KEY=$(python3 -c "
import configparser, os
p = os.path.expanduser('~/.aws/credentials')
if os.path.exists(p):
    c = configparser.ConfigParser()
    c.read(p)
    print(c.get('default', 'aws_access_key_id', fallback=''))
" 2>/dev/null)
        PE_AWS_SECRET=$(python3 -c "
import configparser, os
p = os.path.expanduser('~/.aws/credentials')
if os.path.exists(p):
    c = configparser.ConfigParser()
    c.read(p)
    print(c.get('default', 'aws_secret_access_key', fallback=''))
" 2>/dev/null)
    fi
    if [ -z "$PE_AWS_REGION" ]; then
        PE_AWS_REGION=$(python3 -c "
import configparser, os
p = os.path.expanduser('~/.aws/config')
if os.path.exists(p):
    c = configparser.ConfigParser()
    c.read(p)
    print(c.get('default', 'region', fallback=''))
" 2>/dev/null)
    fi
    PE_AWS_REGION="${PE_AWS_REGION:-us-east-1}"
}

cmd_init() {
    # --manual flag: fall back to the original wizard
    for arg in "$@"; do
        [[ "$arg" == "--manual" ]] && { _cmd_init_wizard; return; }
    done

    echo -e "${PURPLE}${BOLD}Pocket Eng${NC} — Setup"
    echo ""

    # Check what's already on this Mac
    _detect_local_creds

    # Build list of what the phone needs to provide
    local NEEDS=""
    [ -z "$PE_ANTHROPIC_KEY" ] && NEEDS="${NEEDS:+$NEEDS,}anthropic_key"
    [ -z "$PE_AWS_KEY" ]       && NEEDS="${NEEDS:+$NEEDS,}aws_key,aws_secret"

    if [ -z "$NEEDS" ]; then
        echo -e "  ${GREEN}Found credentials on this Mac.${NC} Open the ${BOLD}Pocket Eng${NC} app and scan to confirm."
    else
        echo -e "  Open the ${BOLD}Pocket Eng${NC} app and scan — it will ask for: ${BOLD}${NEEDS/,/, }${NC}"
    fi
    echo ""

    # Find local LAN IP
    local LOCAL_IP
    LOCAL_IP=$(python3 -c "
import socket
try:
    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    s.connect(('8.8.8.8', 80))
    print(s.getsockname()[0])
    s.close()
except Exception:
    print('127.0.0.1')
" 2>/dev/null)

    local PORT=$((8700 + RANDOM % 300))
    local TOKEN
    TOKEN=$(openssl rand -hex 16)
    local RESULT_FILE
    RESULT_FILE=$(mktemp)
    local PYFILE
    PYFILE=$(mktemp /tmp/pe-pair-XXXX.py)

    cat > "$PYFILE" << 'PYEOF'
import http.server, json, sys, threading, socket, time

token, result_file, port, local_ip, needs = sys.argv[1], sys.argv[2], int(sys.argv[3]), sys.argv[4], sys.argv[5]

# UDP broadcast so phone auto-discovers Mac on same WiFi
DISCOVERY_PORT = 8698
discovery_payload = json.dumps({
    "type": "pe-pair",
    "ip": local_ip,
    "port": port,
    "token": token,
    "needs": needs,
}).encode()

def broadcast_loop():
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    sock.setsockopt(socket.SOL_SOCKET, socket.SO_BROADCAST, 1)
    sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    try:
        while True:
            try:
                sock.sendto(discovery_payload, ('<broadcast>', DISCOVERY_PORT))
            except Exception:
                pass
            time.sleep(2)
    finally:
        sock.close()

threading.Thread(target=broadcast_loop, daemon=True).start()

class Handler(http.server.BaseHTTPRequestHandler):
    def do_POST(self):
        if self.path == '/pair':
            length = int(self.headers.get('Content-Length', 0))
            try:
                data = json.loads(self.rfile.read(length))
                if data.get('token') == token:
                    with open(result_file, 'w') as f:
                        json.dump(data, f)
                    self.send_response(200)
                    self.end_headers()
                    self.wfile.write(b'ok')
                    threading.Thread(target=self.server.shutdown, daemon=True).start()
                    return
            except Exception:
                pass
        self.send_response(400)
        self.end_headers()

    def log_message(self, *a): pass

http.server.HTTPServer(('0.0.0.0', port), Handler).serve_forever()
PYEOF

    python3 "$PYFILE" "$TOKEN" "$RESULT_FILE" "$PORT" "$LOCAL_IP" "$NEEDS" &
    local LISTENER_PID=$!

    # Same-network hint (phone auto-discovers via UDP broadcast on port 8698)
    echo -e "  ${GREEN}On the same WiFi?${NC} Open ${BOLD}Pocket Eng${NC} — it will find your Mac automatically."
    echo -e "  ${DIM}Different network? Scan below.${NC}"
    echo ""
    # Encode what the phone needs to collect in the QR
    generate_qr "pe-pair://$LOCAL_IP:$PORT?token=$TOKEN&needs=$NEEDS"
    echo ""
    echo -e "  ${DIM}Waiting for Pocket Eng app...  Ctrl+C to cancel${NC}"
    echo ""

    # Wait up to 5 minutes for phone to connect
    local WAITED=0
    while [ ! -s "$RESULT_FILE" ] && [ $WAITED -lt 300 ]; do
        sleep 1
        WAITED=$((WAITED + 1))
    done
    kill $LISTENER_PID 2>/dev/null
    rm -f "$PYFILE"

    if [ ! -s "$RESULT_FILE" ]; then
        rm -f "$RESULT_FILE"
        echo -e "${RED}Timed out.${NC} Run ${BOLD}pocketeng init --manual${NC} to set up without the app."
        exit 1
    fi

    echo -e "  ${GREEN}Phone connected!${NC}"
    echo ""

    # Read action from phone: "provision" (new EC2) or "connect" (existing server)
    local _action
    _action=$(python3 -c "import json,sys;d=json.load(open(sys.argv[1]));print(d.get('action','provision'))" "$RESULT_FILE")
    PE_SERVER_NAME=$(python3 -c "import json,sys;d=json.load(open(sys.argv[1]));print(d.get('server_name','default'))" "$RESULT_FILE")

    if [ "$_action" = "connect" ]; then
        # Phone is restoring an existing server to this Mac (e.g. new laptop, lost config)
        local _host _user _key_b64 _dir _key_file
        _host=$(python3 -c "import json,sys;d=json.load(open(sys.argv[1]));print(d.get('host',''))" "$RESULT_FILE")
        _user=$(python3 -c "import json,sys;d=json.load(open(sys.argv[1]));print(d.get('user','ec2-user'))" "$RESULT_FILE")
        _key_b64=$(python3 -c "import json,sys;d=json.load(open(sys.argv[1]));print(d.get('ssh_key',''))" "$RESULT_FILE")
        _dir=$(python3 -c "import json,sys;d=json.load(open(sys.argv[1]));print(d.get('dir','~/projects'))" "$RESULT_FILE")
        rm -f "$RESULT_FILE"

        if [ -z "$_host" ] || [ -z "$_key_b64" ]; then
            echo -e "${RED}Incomplete server info from app.${NC}"
            exit 1
        fi

        mkdir -p "$CONFIG_DIR"
        _key_file="$CONFIG_DIR/pe-restored-${PE_SERVER_NAME}.pem"
        echo "$_key_b64" | base64 -d > "$_key_file"
        chmod 600 "$_key_file"

        EC2_HOST="$_host"
        EC2_USER="$_user"
        SSH_KEY="$_key_file"
        WORK_DIR="$_dir"
        save_config "$PE_SERVER_NAME"

        echo -e "  Restored ${BOLD}$PE_SERVER_NAME${NC} → ${BOLD}$_host${NC}"
        echo ""
        echo -n "  Testing connection... "
        if ssh_cmd -o BatchMode=yes "echo ok" &>/dev/null; then
            echo -e "${GREEN}Connected!${NC}"
            echo ""
            echo -e "  Run ${BOLD}pocketeng${NC} to start."
        else
            echo -e "${YELLOW}Could not connect${NC} — server may be stopped."
        fi
    else
        # Provision a new EC2
        # Phone fills in only what was missing locally; use local creds for the rest
        echo -e "  Spinning up your EC2..."
        echo ""
        [ -z "$PE_ANTHROPIC_KEY" ] && PE_ANTHROPIC_KEY=$(python3 -c "import json,sys;d=json.load(open(sys.argv[1]));print(d.get('anthropic_key',''))" "$RESULT_FILE")
        [ -z "$PE_AWS_KEY" ]       && PE_AWS_KEY=$(python3 -c "import json,sys;d=json.load(open(sys.argv[1]));print(d.get('aws_key',''))" "$RESULT_FILE")
        [ -z "$PE_AWS_SECRET" ]    && PE_AWS_SECRET=$(python3 -c "import json,sys;d=json.load(open(sys.argv[1]));print(d.get('aws_secret',''))" "$RESULT_FILE")
        local _phone_region
        _phone_region=$(python3 -c "import json,sys;d=json.load(open(sys.argv[1]));print(d.get('aws_region',''))" "$RESULT_FILE")
        [ -n "$_phone_region" ] && PE_AWS_REGION="$_phone_region"
        local _tools
        _tools=$(python3 -c "import json,sys;d=json.load(open(sys.argv[1]));print(','.join(d.get('tools',[])))" "$RESULT_FILE")
        PE_GITHUB=$([[ "$_tools" == *"github"* ]] && echo "y" || echo "n")
        PE_GITHUB_TOKEN=$(python3 -c "import json,sys;d=json.load(open(sys.argv[1]));print(d.get('github_token',''))" "$RESULT_FILE")
        PE_VERCEL=$([[ "$_tools" == *"vercel"* ]] && echo "y" || echo "n")
        PE_VERCEL_TOKEN=$(python3 -c "import json,sys;d=json.load(open(sys.argv[1]));print(d.get('vercel_token',''))" "$RESULT_FILE")
        PE_SUPABASE=$([[ "$_tools" == *"supabase"* ]] && echo "y" || echo "n")
        PE_SUPABASE_TOKEN=$(python3 -c "import json,sys;d=json.load(open(sys.argv[1]));print(d.get('supabase_token',''))" "$RESULT_FILE")
        PE_DOCKER=$([[ "$_tools" == *"docker"* ]] && echo "y" || echo "n")
        PE_CODEX=$([[ "$_tools" == *"codex"* ]] && echo "y" || echo "n")
        PE_OPENAI_KEY=$(python3 -c "import json,sys;d=json.load(open(sys.argv[1]));print(d.get('openai_key',''))" "$RESULT_FILE")
        PE_AWSCLI="y"
        rm -f "$RESULT_FILE"

        _do_provision
    fi
}

